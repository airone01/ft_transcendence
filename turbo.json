{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "setup": {
      "dependsOn": ["^setup"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["setup", "paraglide"],
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "paraglide": {
      "dependsOn": ["^paraglide"]
    },
    "paraglide:watch": {
      "dependsOn": ["^paraglide:watch"],
      "cache": false,
      "persistent": true
    }
  }
}
