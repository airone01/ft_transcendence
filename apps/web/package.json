{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@transc/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host --clearScreen=false",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "paraglide": "bun run paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "paraglide:watch": "bun run paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "setup": "bun run src/lib/server/db-services/internal/db.seed.ts"
  },
  "peerDependencies": {
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.0",
    "@dicebear/core": "^9.4.0",
    "@transc/db": "workspace:*",
    "@transc/ui": "workspace:*",
    "argon2": "^0.44.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "pg": "^8.18.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sveltekit-superforms": "^2.29.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@fontsource-variable/merriweather": "^5.2.6",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@inlang/paraglide-js": "^2.9.1",
    "@lucide/svelte": "^0.569.0",
    "@playwright/test": "1.57.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "@types/sharp": "^0.32.0",
    "bun-types": "^1.3.8",
    "svelte": "^5.48.2",
    "svelte-check": "^4.3.5",
    "svelte-dnd-action": "^0.9.69",
    "svelte-sonner": "^1.0.7",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "overrides": {
    "playwright": "1.57.0",
    "@playwright/test": "1.57.0",
    "playwright-core": "1.57.0"
  },
  "resolutions": {
    "playwright": "1.57.0",
    "@playwright/test": "1.57.0",
    "playwright-core": "1.57.0"
  }
}
