{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "transc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "^bun@1.3.6",
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose up",
    "check": "turbo run check",
    "prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose down",
    "lint": "$(./biome.sh) check .",
    "format": "$(./biome.sh) check . --fix",
    "db:studio": "bun run --cwd packages/db db:studio",
    "paraglide": "bun run --cwd apps/web paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "paraglide:watch": "bun run --cwd apps/web paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "turbo": "^2.7"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
