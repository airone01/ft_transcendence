{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "transc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "^bun@1.3.6",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "$(./scripts/biome.sh) check .",
    "format": "$(./scripts/biome.sh) check . --fix",
    "dev": "docker compose -f docker-compose.dev.yml up -d --wait && turbo run dev paraglide:watch",
    "prod": "docker compose -f docker-compose.prod.yml up -d",
    "prod:build": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:setup": "./scripts/deprec_db.sh",
    "db:push": "./scripts/deprec_db.sh",
    "db:seed": "./scripts/deprec_db.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "turbo": "^2.7"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
